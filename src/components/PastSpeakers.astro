---
import { pastSpeakers } from "../data/pastSpeakers";

const base = import.meta.env.BASE_URL;
---

<section id="past-speakers" class="bg-ink text-cream">
    <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="grid gap-12 md:grid-cols-12">
            <div
                class="space-y-6 text-xl leading-relaxed md:col-span-6 md:text-2xl"
            >
                <p>
                    A look at the builders, founders, and researchers who took
                    the stage in 2025. You're in good company.
                </p>
            </div>
        </div>

        <ul
            class="mt-12 grid grid-cols-2 gap-x-5 gap-y-10 sm:grid-cols-3 md:mt-16 md:grid-cols-4 lg:grid-cols-5"
        >
            {
                pastSpeakers.map((s) => (
                    <li>
                        <div class="aspect-square w-full overflow-hidden rounded-lg bg-white/5">
                            <img
                                src={`${base}images/past-speakers/${s.image}`}
                                alt={s.name}
                                loading="lazy"
                                width="600"
                                height="600"
                                class="h-full w-full object-cover"
                            />
                        </div>
                        <div class="mt-3">
                            <div class="text-base leading-tight md:text-lg">
                                {s.name}
                            </div>
                            <div class="mt-1 font-mono text-xs leading-snug text-faint">
                                {s.role}
                                {s.org && (
                                    <>
                                        {s.role && " / "}
                                        {s.org}
                                    </>
                                )}
                            </div>
                        </div>
                    </li>
                ))
            }
        </ul>
    </div>
</section>
